{
  "name": "vue-vkontakte-icons",
  "version": "3.46.0",
  "description": "A Vue 3 Vkontakte Icon Component Library.",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "ivanmem",
  "license": "MIT",
  "files": [
    "dist/",
    "src/assets/",
    "volar.d.ts",
    "web-types.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ivanmem/vue-vkontakte-icons.git"
  },
  "keywords": [
    "vue-vkontakte-icons",
    "component library",
    "vue",
    "vkontakte"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "generate-icons": "cross-env GENERATE_ICONS=true vite build"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "6.0.5",
    "@vkontakte/icons": "3.46.0",
    "@vue/tsconfig": "0.7.0",
    "cross-env": "7.0.3",
    "es-toolkit": "1.45.1",
    "fs-extra": "^11.1.1",
    "path": "0.12.7",
    "typescript": "5.9.3",
    "vite": "8.0.3",
    "vite-plugin-dts": "4.5.4",
    "vite-svg-loader": "5.1.1",
    "vue": "3.5.32",
    "vue-tsc": "3.2.6"
  },
  "peerDependencies": {
    "vue": ">=3.2.13"
  }
}